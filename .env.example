# API Configuration
# Copy this file to .env.local for local development
# Copy this file to .env.production for production builds

# Backend API URL
# For local development: leave empty to use Vite proxy
# For production: use your production backend URL
VITE_API_URL=https://sap-technologies-ug.onrender.com

# Environment
# Options: development, production
VITE_ENV=production

# Google AdSense
# Publisher ID is public and should look like ca-pub-1234567890123456.
# This matches public/ads.txt by default, but can be overridden per environment.
VITE_ADSENSE_CLIENT=ca-pub-7847110611874114
VITE_ADSENSE_AUTO_ADS=true
VITE_ADSENSE_DISABLED=false
VITE_ADSENSE_ENABLE_IN_DEV=false

# Optional manual responsive ad unit slots from your AdSense dashboard.
# Leave empty if you only want Auto ads.
VITE_ADSENSE_SLOT_HOME_TOP=2403405277
VITE_ADSENSE_SLOT_HOME_MIDDLE=9455898784
VITE_ADSENSE_SLOT_MARKETPLACE=2100152948
VITE_ADSENSE_SLOT_PAGE_TOP=9731230954
VITE_ADSENSE_SLOT_PAGE_BOTTOM=4478904270
VITE_ADSENSE_SLOT_SOFTWARE=4967961655
VITE_ADSENSE_SLOT_IOT=5479097545
